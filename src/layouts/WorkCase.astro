---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  summary: string;
  role: string;
  stack?: string[];
  outcome: string;
}

const { title, summary, role, stack = [], outcome } = Astro.props;
---

<BaseLayout title={title} description={summary}>
  <article class="section-tight">
    <div class="container">
      <a href="/work" class="meta" style="display:inline-block;margin-bottom:1rem">&larr; All work</a>
      <h1 class="page-title">{title}</h1>
      <p class="lead">{summary}</p>

      <div class="card" style="margin:2rem 0">
        <div class="cv-row" style="border:none;padding:0.4rem 0">
          <h3>Role</h3>
          <div>{role}</div>
        </div>
        <div class="cv-row" style="padding:0.4rem 0">
          <h3>Stack</h3>
          <div class="skills">
            {stack.map((s) => <span class="tag">{s}</span>)}
          </div>
        </div>
        <div class="cv-row" style="padding:0.4rem 0">
          <h3>Outcome</h3>
          <div class="muted">{outcome}</div>
        </div>
      </div>

      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</BaseLayout>
